# Required for opencode serve
OPENCODE_SERVER_AUTH_TOKEN=replace_me
OPENCODE_SERVER_PASSWORD=replace_me

# Example cloud model provider settings. Keep only what you use.
OPENAI_API_KEY=replace_me
ANTHROPIC_API_KEY=replace_me
GOOGLE_API_KEY=replace_me

# Optional runtime config
OPENCODE_MODEL_PROVIDER=openai
OPENCODE_MODEL=gpt-5
OPENCODE_AUDIT_ENDPOINT=http://audit:8081/ingest
